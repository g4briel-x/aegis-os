diff --git a/tests/runtime/test_cli_asset_commands.py b/tests/runtime/test_cli_asset_commands.py
new file mode 100644
--- /dev/null
+++ b/tests/runtime/test_cli_asset_commands.py
@@ -0,0 +1,88 @@
+from pathlib import Path
+
+from aegis_runtime.cli import EXIT_OK, main
+
+
+def _create_repository(tmp_path: Path) -> None:
+    asset_path = tmp_path / "skills" / "security" / "review.md"
+    asset_path.parent.mkdir(parents=True)
+    asset_path.write_text("# Review API Security", encoding="utf-8")
+
+    skills_registry = tmp_path / "registry" / "skills"
+    skills_registry.mkdir(parents=True)
+    (skills_registry / "skills.registry.yaml").write_text(
+        """
+entries:
+  - id: security.review-api-security
+    name: Review API Security
+    type: skill
+    domain: security
+    path: skills/security/review.md
+    tags:
+      - api
+      - security
+""".strip(),
+        encoding="utf-8",
+    )
+
+    domains_registry = tmp_path / "registry" / "domains"
+    domains_registry.mkdir(parents=True)
+    (domains_registry / "domains.registry.yaml").write_text(
+        """
+domains:
+  - id: domain.security
+    name: Security
+    slug: security
+""".strip(),
+        encoding="utf-8",
+    )
+
+    tags_registry = tmp_path / "registry" / "tags"
+    tags_registry.mkdir(parents=True)
+    (tags_registry / "tags.registry.yaml").write_text(
+        """
+tags:
+  - id: tag.api
+    name: API
+    category: engineering
+""".strip(),
+        encoding="utf-8",
+    )
+
+
+def test_registry_catalog_commands_do_not_break_asset_show(
+    tmp_path: Path,
+    capsys,
+) -> None:
+    _create_repository(tmp_path)
+
+    domains_exit = main(
+        ["--repo-root", str(tmp_path), "registry", "domains"]
+    )
+    domains_output = capsys.readouterr().out
+
+    asset_exit = main(
+        [
+            "--repo-root",
+            str(tmp_path),
+            "asset",
+            "show",
+            "security.review-api-security",
+        ]
+    )
+    asset_output = capsys.readouterr().out
+
+    assert domains_exit == EXIT_OK
+    assert "domain.security" in domains_output
+    assert asset_exit == EXIT_OK
+    assert "ID: security.review-api-security" in asset_output
+
+
+def test_asset_find_remains_reachable(tmp_path: Path, capsys) -> None:
+    _create_repository(tmp_path)
+    exit_code = main(
+        ["--repo-root", str(tmp_path), "asset", "find", "security"]
+    )
+    output = capsys.readouterr().out
+    assert exit_code == EXIT_OK
+    assert "security.review-api-security" in output
