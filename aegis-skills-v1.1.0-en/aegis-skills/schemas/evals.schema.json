{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.local/schemas/evals.schema.json",
  "title": "Aegis Skill Evals",
  "type": "object",
  "required": [
    "skill_name",
    "evals"
  ],
  "properties": {
    "skill_name": {
      "type": "string"
    },
    "evals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "prompt",
          "expected_output",
          "files"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "prompt": {
            "type": "string",
            "minLength": 1
          },
          "expected_output": {
            "type": "string",
            "minLength": 1
          },
          "files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
