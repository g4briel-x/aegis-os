{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.local/schemas/skill-manifest.schema.json",
  "title": "Aegis Skill Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "display_name",
    "version",
    "status",
    "category",
    "entrypoint",
    "description",
    "capabilities"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxLength": 64
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "status": {
      "enum": [
        "draft",
        "active",
        "deprecated"
      ]
    },
    "category": {
      "type": "string",
      "pattern": "^\\d{2}-[a-z0-9-]+$"
    },
    "entrypoint": {
      "const": "SKILL.md"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  }
}
