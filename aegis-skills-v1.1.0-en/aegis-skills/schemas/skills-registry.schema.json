{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.local/schemas/skills-registry.schema.json",
  "title": "Aegis Skills Registry",
  "type": "object",
  "required": [
    "schema_version",
    "library_version",
    "skills"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "library_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "display_name",
          "version",
          "category",
          "path",
          "entrypoint",
          "status"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "entrypoint": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      }
    }
  }
}
